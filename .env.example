# ─── Figma ────────────────────────────────────────────────────────────────────
# Get from: figma.com → Account Settings → Personal Access Tokens
FIGMA_TOKEN=figd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Anthropic / Claude AI ────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── WordPress ────────────────────────────────────────────────────────────────
# Your WordPress site URL (no trailing slash)
WP_URL=https://yoursite.com

# WordPress admin username
WP_USER=admin

# WP Application Password (from: WP Admin → Users → Profile → Application Passwords)
# Format: xxxx xxxx xxxx xxxx xxxx xxxx  (spaces are fine — they're stripped automatically)
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── Optional Settings ────────────────────────────────────────────────────────
# Delay (ms) between Claude API calls to avoid rate limits. Default: 500
RATE_LIMIT_MS=500

# Directory to write all generated files. Default: ./output
OUTPUT_DIR=./output

# Claude model to use. Default: claude-opus-4-6
CLAUDE_MODEL=claude-opus-4-6
